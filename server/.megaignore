# Start of generated .megaignore using git2megaignore v0.4.0
# For more info visit: https://github.com/Farfi55/git2megaignore.git

+sync:.megaignore
# from __pycache__/
-dnG:__pycache__
# from data/
-dnG:data
# from logs/
-dnG:logs
# from .coverage
-nG:.coverage
# from coverage.xml
-nG:coverage.xml
# End of generated .megaignore
