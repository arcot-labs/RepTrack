{
    "name": "rep-track",
    "private": true,
    "scripts": {
        "check:py": "uv run --project server pyright",
        "format": "npm run prettier && npm run format:py",
        "format:py": "uv run --project server ruff format server",
        "lint": "npm run lint:py && npm run check:py && cd client && npm run lint",
        "lint:py": "uv run --project server ruff check server --fix",
        "prepare": "husky && npm run sort-package-jsons",
        "prettier": "prettier . --write",
        "sort-package-jsons": "sort-package-json && sort-package-json client/package.json"
    },
    "lint-staged": {
        "*.py": [
            "uv run --project server pyright",
            "uv run --project server ruff check --fix",
            "uv run --project server ruff format"
        ],
        "*": "prettier --write --ignore-unknown --ignore-path .prettierignore"
    },
    "dependencies": {
        "sort-package-json": "^3.6.1"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.3.1",
        "npm-check-updates": "^19.6.3",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "prettier-plugin-toml": "2.0.6"
    }
}
